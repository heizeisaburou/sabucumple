<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Feliz Cumpleaños Sabu</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }

    html, body {
      height: 100%;
      overflow: hidden;
    }
    body {
      height: 100dvh;
      background: radial-gradient(ellipse at center, #1a1a2e 0%, #0d0d1a 100%);
      display: flex;
      justify-content: center;
      align-items: center;
      font-family: 'Segoe UI', 'Yu Gothic', system-ui, sans-serif;
      position: relative;
    }

    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image:
        radial-gradient(circle at 25% 25%, rgba(201, 169, 110, 0.03) 1px, transparent 1px),
        radial-gradient(circle at 75% 75%, rgba(139, 0, 0, 0.03) 1px, transparent 1px);
      background-size: 60px 60px;
      pointer-events: none;
      z-index: 0;
    }

    canvas#confetti-canvas {
      position: fixed;
      inset: 0;
      pointer-events: none;
      z-index: 10;
    }

    .container {
      position: relative;
      z-index: 2;
      text-align: center;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      height: 100dvh;
      padding: clamp(8px, 2vh, 20px) clamp(8px, 2vw, 20px);
    }

    .neon-wrapper { margin-bottom: clamp(4px, 1.2vh, 15px); }

    .neon-sign {
      font-size: clamp(1rem, 4.5vh, 2.8rem);
      font-weight: 900;
      letter-spacing: 4px;
      text-transform: uppercase;
      color: #fff;
      text-shadow:
        0 0 7px #ff2d55, 0 0 10px #ff2d55, 0 0 21px #ff2d55,
        0 0 42px #ff2d55, 0 0 82px #ff2d55, 0 0 92px #ff2d55;
      animation: flicker 3s infinite alternate;
      line-height: 1.2;
    }

    .neon-sabu {
      font-size: clamp(1.3rem, 5.5vh, 3.5rem);
      font-weight: 900;
      letter-spacing: 14px;
      text-transform: uppercase;
      color: #fff;
      text-shadow:
        0 0 7px #f1c40f, 0 0 14px #f1c40f, 0 0 28px #f1c40f,
        0 0 56px #f1c40f, 0 0 100px #f1c40f, 0 0 140px #f1c40f;
      animation: flickerGold 2.5s infinite alternate;
      line-height: 1.2;
      margin-top: 4px;
    }

    @keyframes flickerGold {
      0%,19%,21%,23%,25%,54%,56%,100% {
        text-shadow:
          0 0 7px #f1c40f, 0 0 14px #f1c40f, 0 0 28px #f1c40f,
          0 0 56px #f1c40f, 0 0 100px #f1c40f, 0 0 140px #f1c40f;
      }
      20%,24%,55% {
        text-shadow:
          0 0 2px #fff, 0 0 4px #fff, 0 0 6px #fff,
          0 0 10px #f1c40f, 0 0 20px #f1c40f;
      }
    }

    @keyframes flicker {
      0%,19%,21%,23%,25%,54%,56%,100% {
        text-shadow: 0 0 7px #ff2d55, 0 0 10px #ff2d55, 0 0 21px #ff2d55, 0 0 42px #ff2d55, 0 0 82px #ff2d55, 0 0 92px #ff2d55;
      }
      20%,24%,55% {
        text-shadow: 0 0 2px #fff, 0 0 4px #fff, 0 0 6px #fff, 0 0 10px #ff2d55, 0 0 20px #ff2d55;
      }
    }

    .photo-group {
      display: inline-block;
      margin: clamp(10px, 4vh, 50px) clamp(10px, 4vw, 50px);
    }

    .photo-grid {
      display: grid;
      grid-template-columns: auto 1fr auto;
      grid-template-rows: auto 1fr auto;
      align-items: center;
      justify-items: center;
      gap: clamp(2px, 0.8vh, 8px);
    }

    .photo-wrapper {
      position: relative;
      grid-column: 2;
      grid-row: 2;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .photo-wrapper::before {
      content: '';
      position: absolute;
      inset: -5px;
      border-radius: 50%;
      background: conic-gradient(#ff2d55, #ffb7c5, #c9a96e, #ff2d55);
      animation: spin 4s linear infinite;
      z-index: -1;
    }

    .photo {
      width: clamp(90px, 20vmin, 190px);
      height: clamp(90px, 20vmin, 190px);
      border-radius: 50%;
      object-fit: cover;
      border: 3px solid rgba(255,255,255,0.9);
      display: block;
      box-shadow: 0 0 30px rgba(255,45,85,0.3);
    }

    @keyframes spin { to { transform: rotate(360deg); } }

    .girl {
      width: clamp(75px, 14vmin, 180px);
      position: relative;
      filter: brightness(1.15) contrast(1.1) drop-shadow(0 0 30px rgba(255,255,255,0.4)) drop-shadow(0 0 60px rgba(201,169,110,0.15));
      z-index: 3;
      transition: transform 0.3s ease;
    }

    .girl::before {
      content: '';
      position: absolute;
      inset: -15%;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(255,230,200,0.35) 0%, rgba(255,200,200,0.15) 40%, transparent 70%);
      z-index: -1;
      pointer-events: none;
      animation: glowPulse 3s ease-in-out infinite alternate;
    }

    @keyframes glowPulse {
      0% { opacity: 0.6; transform: scale(0.95); }
      100% { opacity: 1; transform: scale(1.05); }
    }

    .girl svg { width: 100%; height: auto; display: block; }
    .girl-img { width: 100%; height: auto; display: block; position: relative; z-index: 1; border-radius: 8px; }

    .girl-tl { grid-column: 1; grid-row: 1; }
    .girl-tr { grid-column: 3; grid-row: 1; }
    .girl-bl { grid-column: 1; grid-row: 3; }
    .girl-br { grid-column: 3; grid-row: 3; }

    @keyframes danceTL {
      0%,100% { transform: rotate(-3deg) translateY(0); }
      50% { transform: rotate(3deg) translateY(-6px); }
    }
    @keyframes danceTR {
      0%,100% { transform: rotate(3deg) translateY(0); }
      50% { transform: rotate(-3deg) translateY(-6px); }
    }
    @keyframes danceBL {
      0%,100% { transform: translateY(0); }
      25% { transform: translateY(-5px) rotate(-4deg); }
      75% { transform: translateY(-3px) rotate(4deg); }
    }
    @keyframes danceBR {
      0%,100% { transform: translateY(0); }
      25% { transform: translateY(-5px) rotate(4deg); }
      75% { transform: translateY(-3px) rotate(-4deg); }
    }

    .girl-tl { animation: danceTL 1.8s ease-in-out infinite; }
    .girl-tr { animation: danceTR 2.2s ease-in-out infinite; }
    .girl-bl { animation: danceBL 1.6s ease-in-out infinite; }
    .girl-br { animation: danceBR 2s ease-in-out infinite; }

    .lanterns {
      display: flex;
      justify-content: center;
      gap: clamp(8px, 1.5vw, 20px);
      margin-top: clamp(2px, 1vh, 12px);
    }

    .lantern {
      width: clamp(14px, 2.5vh, 24px); height: clamp(22px, 4vh, 40px);
      background: radial-gradient(ellipse at center, #e8a0a0, #c0392b);
      border-radius: 50%;
      position: relative;
      box-shadow: 0 0 20px rgba(192,57,43,0.4);
      animation: glow 2s ease-in-out infinite alternate;
    }

    .lantern::before {
      content: '';
      position: absolute; top: -6px; left: 50%;
      transform: translateX(-50%);
      width: 2px; height: 6px; background: #666;
    }

    .lantern::after {
      content: '';
      position: absolute; bottom: 4px; left: 50%;
      transform: translateX(-50%);
      width: 2px; height: 4px;
      background: rgba(255,255,255,0.3);
      border-radius: 50%; filter: blur(2px);
    }

    .lantern:nth-child(2) { animation-delay: 0.7s; }
    .lantern:nth-child(3) { animation-delay: 1.4s; }
    .lantern:nth-child(4) { animation-delay: 0.4s; }
    .lantern:nth-child(5) { animation-delay: 1.1s; }

    .japanese-wrapper {
      margin-top: clamp(2px, 0.8vh, 10px);
    }

    .japanese-neon {
      font-size: clamp(0.7rem, 2.5vh, 1.4rem);
      font-weight: 700;
      letter-spacing: 3px;
      color: #fff;
      text-shadow:
        0 0 5px #ff2d55, 0 0 10px #ff2d55, 0 0 20px #ff2d55,
        0 0 40px #ff2d55, 0 0 60px #ff2d55;
      animation: flicker 3s infinite alternate;
      line-height: 1.3;
      font-family: 'Yu Gothic', 'Segoe UI', sans-serif;
    }

    .japanese-sabu {
      font-size: clamp(0.9rem, 3.5vh, 2rem);
      font-weight: 700;
      letter-spacing: 8px;
      color: #fff;
      text-shadow:
        0 0 5px #f1c40f, 0 0 10px #f1c40f, 0 0 20px #f1c40f,
        0 0 40px #f1c40f, 0 0 70px #f1c40f, 0 0 100px #f1c40f;
      animation: flickerGold 2.5s infinite alternate;
      line-height: 1.3;
      margin-top: 2px;
      font-family: 'Yu Gothic', 'Segoe UI', sans-serif;
    }

    @keyframes glow {
      0% { box-shadow: 0 0 15px rgba(192,57,43,0.3); }
      100% { box-shadow: 0 0 35px rgba(192,57,43,0.7); }
    }

    @media (max-width: 500px) {
      .container { padding: clamp(4px, 1vh, 10px); }
      .photo-group { margin: clamp(5px, 2vh, 20px) clamp(5px, 2vw, 20px); }
      .girl { width: clamp(60px, 16vmin, 100px); }
      .photo { width: clamp(70px, 22vmin, 120px); height: clamp(70px, 22vmin, 120px); }
      .photo-grid { gap: 2px; }
      .neon-sign { font-size: clamp(0.8rem, 3.5vh, 1.5rem); }
      .neon-sabu { font-size: clamp(1rem, 4vh, 1.8rem); letter-spacing: 8px; }
      .lantern { width: 12px; height: 20px; }
      .lanterns { gap: 8px; margin-top: 2px; }
      .japanese-neon { font-size: clamp(0.5rem, 2vh, 0.9rem); }
      .japanese-sabu { font-size: clamp(0.7rem, 2.8vh, 1.2rem); letter-spacing: 4px; }
    }

    @media (max-height: 500px) {
      .neon-wrapper { margin-bottom: 2px; }
      .photo-group { margin: 2px; }
      .neon-sign { font-size: clamp(0.7rem, 3.5vh, 1.2rem); }
      .neon-sabu { font-size: clamp(0.8rem, 4.5vh, 1.5rem); letter-spacing: 6px; }
      .girl { width: clamp(50px, 12vmin, 100px); }
      .photo { width: clamp(60px, 16vmin, 100px); height: clamp(60px, 16vmin, 100px); }
      .lanterns { margin-top: 1px; gap: 6px; }
      .lantern { width: 10px; height: 16px; }
      .japanese-wrapper { margin-top: 1px; }
      .japanese-neon { font-size: clamp(0.4rem, 2vh, 0.7rem); }
      .japanese-sabu { font-size: clamp(0.5rem, 2.5vh, 0.9rem); letter-spacing: 3px; }
    }
  </style>
</head>
<body>

  <canvas id="confetti-canvas"></canvas>

  <div class="container">

    <div class="neon-wrapper">
      <h1 class="neon-sign">Feliz Cumpleaños</h1>
      <div class="neon-sabu">S A B U</div>
    </div>

    <div class="photo-group">
      <div class="photo-grid">

        <!-- Girl TL -->
        <div class="girl girl-tl">
          <img src="assets/Chica%20uno.png" alt="Chica 1" class="girl-img">
        </div>

        <!-- Girl TR -->
        <div class="girl girl-tr">
          <img src="assets/Chica%20dos.png" alt="Chica 2" class="girl-img">
        </div>

        <!-- Girl BL -->
        <div class="girl girl-bl">
          <img src="assets/Chica%20tres.png" alt="Chica 3" class="girl-img">
        </div>

        <!-- Girl BR -->
        <div class="girl girl-br">
          <img src="assets/Chica%20cuatro.png" alt="Chica 4" class="girl-img">
        </div>

        <!-- Photo -->
        <div class="photo-wrapper">
          <img src="assets/Saburo.png" alt="Saburo" class="photo">
        </div>

      </div>
    </div>

    <div class="lanterns">
      <div class="lantern"></div>
      <div class="lantern"></div>
      <div class="lantern"></div>
      <div class="lantern"></div>
      <div class="lantern"></div>
    </div>

    <div class="japanese-wrapper">
      <div class="japanese-neon">お誕生日おめでとう</div>
      <div class="japanese-sabu">サブ</div>
    </div>

  </div>

  <!-- Music: YOASOBI - Idol (Oshi no Ko OP) -->
  <div id="yt-player"></div>
  <div id="music-label" style="position:fixed;bottom:12px;right:12px;z-index:20;color:rgba(255,255,255,0.2);font-size:11px;font-family:'Segoe UI',sans-serif;pointer-events:none;opacity:0;transition:opacity 1s;">♪ YOASOBI - Idol</div>

  <script>
    var tag = document.createElement('script');
    tag.src = 'https://www.youtube.com/iframe_api';
    var firstScriptTag = document.getElementsByTagName('script')[0];
    firstScriptTag.parentNode.insertBefore(tag, firstScriptTag);

    var player;
    function onYouTubeIframeAPIReady() {
      player = new YT.Player('yt-player', {
        height: '0', width: '0',
        videoId: 'ZRtdQ81jPUQ',
        playerVars: { autoplay: 0, loop: 1, playlist: 'ZRtdQ81jPUQ', controls: 0, modestbranding: 1, rel: 0 },
        events: {
          onReady: function(e) { e.target.setVolume(40); }
        }
      });
    }

    function startMusic() {
      if (player && player.playVideo) { player.playVideo(); }
      document.getElementById('music-label').style.opacity = '1';
      document.removeEventListener('click', startMusic);
      document.removeEventListener('touchstart', startMusic);
    }
    document.addEventListener('click', startMusic);
    document.addEventListener('touchstart', startMusic);

    (function() {
      const canvas = document.getElementById('confetti-canvas');
      const ctx = canvas.getContext('2d');
      let W, H;
      function resize() { W = canvas.width = window.innerWidth; H = canvas.height = window.innerHeight; }
      resize();
      window.addEventListener('resize', resize);
      const pieces = [];
      const COLORS = ['#ff2d55','#ffb7c5','#f1c40f','#c9a96e','#9b59b6','#e74c3c','#3498db','#2ecc71','#fff'];
      function Piece() { this.reset(); }
      Piece.prototype.reset = function() {
        this.x = Math.random()*W; this.y = Math.random()*H-H;
        this.w = 5+Math.random()*5; this.h = 3+Math.random()*7;
        this.vx = (Math.random()-0.5)*2; this.vy = 1+Math.random()*2.5;
        this.color = COLORS[Math.floor(Math.random()*COLORS.length)];
        this.rotation = Math.random()*360; this.rotSpeed = (Math.random()-0.5)*5;
        this.opacity = 0.7+Math.random()*0.3;
      };
      Piece.prototype.update = function() {
        this.x+=this.vx; this.y+=this.vy; this.rotation+=this.rotSpeed;
        if(this.y>H+20) this.reset();
      };
      Piece.prototype.draw = function() {
        ctx.save(); ctx.translate(this.x,this.y);
        ctx.rotate(this.rotation*Math.PI/180);
        ctx.globalAlpha=this.opacity; ctx.fillStyle=this.color;
        ctx.fillRect(-this.w/2,-this.h/2,this.w,this.h);
        ctx.restore();
      };
      for(let i=0;i<120;i++) pieces.push(new Piece());
      setTimeout(()=>{pieces.forEach(p=>{p.y=Math.random()*H;p.vy=2+Math.random()*5})},300);
      (function animate(){ctx.clearRect(0,0,W,H);pieces.forEach(p=>{p.update();p.draw()});requestAnimationFrame(animate)})();
    })();
  </script>

</body>
</html>